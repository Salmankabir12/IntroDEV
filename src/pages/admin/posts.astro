---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { sanityClient } from '../../lib/sanity';
import { getAllPostsQuery } from '../../lib/queries';

const posts = await sanityClient.fetch(getAllPostsQuery);
---

<AdminLayout title="Posts">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">Posts</h1>
    <a
      href="/admin/posts/new"
      class="px-4 py-2 rounded-lg bg-gradient-to-r from-indigo-500 to-cyan-500 text-sm font-medium hover:opacity-90 transition"
    >
      + New Post
    </a>
  </div>

  {posts.length === 0 ? (
    <p class="text-(--text-muted)">No posts yet.</p>
  ) : (
    <div class="bg-(--surface-elevated) border border-(--border) rounded-xl overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-(--border) bg-(--surface-raised)">
            <th class="text-left px-4 py-3 font-medium text-(--text-muted)">Title</th>
            <th class="text-left px-4 py-3 font-medium text-(--text-muted) hidden md:table-cell">Tags</th>
            <th class="text-left px-4 py-3 font-medium text-(--text-muted) hidden sm:table-cell">Date</th>
            <th class="text-right px-4 py-3 font-medium text-(--text-muted)">Actions</th>
          </tr>
        </thead>
        <tbody>
          {posts.map((post: any) => (
            <tr class="border-b border-(--border) hover:bg-(--surface-raised) transition">
              <td class="px-4 py-3 font-medium">{post.title}</td>
              <td class="px-4 py-3 text-(--text-muted) hidden md:table-cell">
                {post.tags?.slice(0, 3).join(', ') || '—'}
              </td>
              <td class="px-4 py-3 text-(--text-muted) hidden sm:table-cell">
                {post.publishedAt ? new Date(post.publishedAt).toLocaleDateString() : '—'}
              </td>
              <td class="px-4 py-3 text-right">
                <a
                  href={`/admin/posts/edit/${post.slug.current}`}
                  class="text-indigo-500 hover:text-indigo-400 text-xs font-medium"
                >
                  Edit
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>
