---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { projects } from '../../data/projects';
---

<AdminLayout title="Projects">
  <h1 class="text-2xl font-bold mb-6">Projects</h1>

  <p class="text-sm text-(--text-muted) mb-6">
    Projects are defined in <code class="text-indigo-500">src/data/projects.ts</code>. Edit the source file to add or modify projects.
  </p>

  <div class="space-y-4">
    {projects.map((p) => (
      <div class="p-5 bg-(--surface-elevated) border border-(--border) rounded-xl">
        <div class="flex items-start justify-between mb-2">
          <h2 class="text-lg font-semibold">{p.title}</h2>
          <span class="text-xs px-2 py-1 bg-(--tag) text-(--tag-text) rounded">{p.slug}</span>
        </div>
        <p class="text-sm text-(--text-secondary) mb-3">{p.description}</p>
        <div class="flex flex-wrap gap-2">
          {p.techStack.map((t: string) => (
            <span class="text-xs px-2 py-1 bg-(--tag) text-(--tag-text) rounded">{t}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</AdminLayout>
